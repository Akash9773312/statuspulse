# Copy to .env and adjust values before deploying:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Application (FastAPI)
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=statuspulse
DB_USER=statuspulse
DB_PASSWORD=change-me

REDIS_HOST=redis
REDIS_PORT=6379
# Leave empty if Redis has no password
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# PostgreSQL (docker-compose postgres service)
# Keep POSTGRES_* in sync with DB_* above
# -----------------------------------------------------------------------------
POSTGRES_DB=statuspulse
POSTGRES_USER=statuspulse
POSTGRES_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Domain (used by Caddy / bootstrap; set in terraform/terraform.tfvars)
# -----------------------------------------------------------------------------
# DOMAIN_NAME=statuspulse.example.com
# KUMA_DOMAIN_NAME=statuspulse-kuma.example.com
