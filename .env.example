# Copy to .env for local development: cp .env.example .env

# Application
DB_HOST=postgres
DB_PORT=5432
DB_NAME=statuspulse
DB_USER=statuspulse
DB_PASSWORD=change-me

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgreSQL container (keep in sync with DB_*)
POSTGRES_DB=statuspulse
POSTGRES_USER=statuspulse
POSTGRES_PASSWORD=change-me

# Production / deploy (set on server or in GitHub Secrets)
APP_IMAGE=ghcr.io/your-org/statuspulse:latest
DOMAIN_NAME=statuspulse.example.com
KUMA_DOMAIN_NAME=statuspulse-kuma.example.com

# Monitoring
ALERT_WEBHOOK_URL=
S3_BUCKET=
